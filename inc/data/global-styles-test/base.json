{
	"styleId": "kbs-base",
	"name": "Base Style",
	"version": "1.0.0",
	"components": {
		"flex": {
			"presets": {
				"base-54321": {
					"label": "Base",
					"name": "Basic Vertical",
					"description": "A basic vertical flex container",
