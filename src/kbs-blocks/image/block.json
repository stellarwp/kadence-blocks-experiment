{
	"apiVersion": 3,
	"title": "Image",
	"name": "kbs/image",
	"category": "kadence-blocks",
	"usesContext": ["postId", "queryId", "kbs/parentGlobalStyles"],
	"textdomain": "kadence-blocks",
	"providesContext": {
		"kbs/parentGlobalStyles": "globalStyleIds"
	},
	"attributes": {
		"uniqueID": {
			"type": "string"
		},
		"anchor": {
			"type": "string"
		},
		"preset": {
			"type": "array"
		},
		"tagName": {
			"type": "string",
			"initial": "div"
		},
		"padding": {
			"type": "object",
			"renderCSS": true,
			"component": "padding",
			"nonInheritable": true,
			"varPrefix": "--kbs-cont-"
		},
		"margin": {
			"type": "object",
			"renderCSS": true,
			"component": "margin",
			"nonInheritable": true,
			"varPrefix": "--kbs-cont-",
			"selectorSuffix": "%selector%"
		},
		"foreground": {
			"renderCSS": true,
			"component": "background",
			"nonInheritable": true,
			"type": "object",
			"varPrefix": "--kbs-cont-",
			"classPrefix": "kbs-cont-bg-",
			"hasLayers": true,
			"selectorSuffix": " .kbs-image-foreground"
		},
		"boxShadow": {
			"renderCSS": true,
			"component": "boxShadow",
			"nonInheritable": true,
			"type": "object",
			"varPrefix": "--kbs-cont-",
			"classPrefix": "kbs-cont-shadow-",
			"hasLayers": true
		},
		"border": {
			"renderCSS": true,
			"component": "border",
			"nonInheritable": true,
			"type": "object",
			"varPrefix": "--kbs-cont-",
			"classPrefix": "kbs-cont-border-"
		},
		"variant": {
			"renderCSS": false,
			"component": "imageVariant",
			"bundlePreset": true,
			"nonInheritable": true,
			"type": "string"
		},
		"minHeight": {
			"renderCSS": true,
			"component": "minHeight",
			"varPrefix": "--kbs-cont-",
			"nonInheritable": true,
			"initial": {},
			"type": "object"
		},
		"typography": {
			"renderCSS": true,
			"component": "typography",
			"varPrefix": "--kbs-cont-",
			"tag": "h1",
			"initial": {},
			"type": "object"
		},
		"globalStyleIds": {
			"type": "array"
		},
		"transform": {
			"renderCSS": true,
			"component": "transform",
			"nonInheritable": true,
			"selector": "--kbs-image-transform-",
			"classPrefix": "kbs-image-transform-",
			"initial": {},
			"type": "object"
		},
		"transformHover": {
			"renderCSS": true,
			"component": "transform",
			"nonInheritable": true,
			"selector": "--kbs-image-transform-",
			"classPrefix": "kbs-image-transform-",
			"initial": {},
			"type": "object"
		},
		"transition": {
			"renderCSS": true,
			"component": "transition",
			"nonInheritable": true,
			"selector": "--kbs-image-transition-",
			"classPrefix": "kbs-image-transition-",
			"initial": {},
			"type": "object"
		},
		"image": {
			"renderCSS": false,
			"component": "image",
			"nonInheritable": true,
			"type": "object"
		},
		"objectPosition": {
			"renderCSS": true,
			"component": "objectPosition",
			"nonInheritable": true,
			"type": "object",
			"varPrefix": "--kbs-image-",
			"classPrefix": "kbs-image-",
			"selectorSuffix": " .kbs-image-img"
		},
		"useRatio": {
			"renderCSS": false,
			"nonInheritable": true,
			"type": "object"
		},
		"ratio": {
			"renderCSS": false,
			"component": "ratio",
			"nonInheritable": true,
			"type": "object",
			"varPrefix": "--kbs-image-",
			"classPrefix": "kbs-image-"
		},
		"maxWidth": {
			"renderCSS": true,
			"component": "maxWidth",
			"type": "object",
			"varPrefix": "--kbs-image-",
			"classPrefix": "kbs-image-"
		},
		"alt": {
			"renderCSS": false,
			"nonInheritable": true,
			"type": "object"
		},
		"title": {
			"renderCSS": false,
			"nonInheritable": true,
			"type": "object"
		},
		"link": {
			"renderCSS": false,
			"nonInheritable": true,
			"type": "object"
		},
		"linkTitle": {
			"renderCSS": false,
			"nonInheritable": true,
			"type": "object"
		}
	},
	"supports": {
		"anchor": true,
		"ktanimate": true,
		"ktanimateadd": true,
		"ktanimatepreview": true,
		"ktanimateswipe": true,
		"ktdynamic": true,
		"kbcss": true,
		"kbMetadata": true
	},
	"editorStyle": "kbs-section-editor",
	"style": "kbs-section"
}
