		"border": {
			"renderCSS": true,
			"component": "border",
			"type": "object",
			"selector": "--kbs-text-",
			"classPrefix": "kbs-text-border-"
		},
		"colorHighlight": {
			"renderCSS": true,
			"component": "color",
			"type": "object",
			"selector": "--kbs-text-highlight-",
			"classPrefix": "kbs-text-color-highlight-"
