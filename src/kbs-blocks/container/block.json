{
	"apiVersion": 3,
	"title": "Container",
	"name": "kbs/container",
	"category": "kadence-blocks",
	"usesContext": ["postId", "queryId", "kbs/parentGlobalStyles", "kbs/parentUniqueId"],
	"textdomain": "kadence-blocks",
	"providesContext": {
		"kbs/parentUniqueId": "uniqueID",
		"kbs/parentGlobalStyles": "globalStyleIds"
	},
	"attributes": {
		"uniqueID": {
			"type": "string"
		},
		"anchor": {
			"type": "string"
		},
		"preset": {
			"type": "array"
		},
		"tagName": {
			"type": "string",
			"initial": "div"
		},
		"flexBox": {
			"renderCSS": true,
			"component": "flexBox",
			"nonInheritable": true,
			"type": "object",
			"selector": "--kbs-cont-",
			"initial": {
				"desktop": {
					"flexDirection": "column",
					"justifyContent": "flex-start",
					"alignItems": "stretch",
					"columnGap": "xs"
				}
			}
		},
		"flexChild": {
			"renderCSS": true,
			"component": "flexChild",
			"nonInheritable": true,
			"type": "object",
			"selector": "--kbs-cont-",
			"initial": {
				"desktop": {
					"flex": "initial"
				}
			}
		},
		"background": {
			"renderCSS": true,
			"component": "background",
			"nonInheritable": true,
			"type": "array",
			"selector": "--kbs-cont-",
			"hasLayers": true,
			"initial": {
				"layers": [
					{
						"desktop": {
							"backgroundColor": "palette7"
						}
					},
					{
						"desktop": {
							"backgroundColor": "palette4"
						}
					}
				]
			}
		},
		"color": {
			"type": "object"
		},
		"border": {
			"type": "object"
		},
		"padding": {
			"type": "object"
		},
		"margin": {
			"type": "object"
		},
		"shadow": {
			"type": "object"
		},
		"visibility": {
			"type": "object"
		},
		"grow": {
			"type": "object"
		},
		"zIndex": {
			"type": "number"
		},
		"order": {
			"type": "object"
		},
		"basis": {
			"type": "object"
		},
		"width": {
			"type": "object"
		},
		"height": {
			"type": "object"
		},
		"templateLock": {
			"type": ["string", "boolean"],
			"enum": ["all", "insert", "contentOnly", false]
		},
		"link": {
			"type": "string"
		},
		"linkExtras": {
			"type": "object"
		},
		"maxHeight": {
			"renderCSS": true,
			"component": "maxHeight",
			"selector": "--kbs-cont-",
			"initial": {},
			"type": "object"
		},
		"typography": {
			"renderCSS": true,
			"component": "typography",
			"selector": "--kbs-cont-",
			"tag": "h1",
			"initial": {},
			"type": "object"
		},
		"globalStyleIds": {
			"type": "array"
		}
	},
	"supports": {
		"anchor": true,
		"ktanimate": true,
		"ktanimateadd": true,
		"ktanimatepreview": true,
		"ktanimateswipe": true,
		"ktdynamic": true,
		"kbcss": true,
		"kbMetadata": true,
		"align": ["wide", "full"]
	},
	"editorStyle": "kbs-section-editor",
	"style": "kbs-section"
}
