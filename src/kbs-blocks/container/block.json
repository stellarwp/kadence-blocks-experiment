{
	"apiVersion": 3,
	"title": "Container",
	"name": "kbs/container",
	"category": "kadence-blocks",
	"usesContext": ["postId", "queryId", "kbs/parentGlobalStyles"],
	"textdomain": "kadence-blocks",
	"providesContext": {
		"kbs/parentGlobalStyles": "globalStyleIds"
	},
	"attributes": {
		"uniqueID": {
			"type": "string"
		},
		"anchor": {
			"type": "string"
		},
		"preset": {
			"type": "array"
		},
		"tagName": {
			"type": "string",
			"initial": "div"
		},
		"flexBox": {
			"renderCSS": true,
			"component": "flexBox",
			"nonInheritable": true,
			"type": "object",
			"varPrefix": "--kbs-cont-",
			"initial": {
				"desktop": {
					"flexDirection": "column",
					"justifyContent": "flex-start",
					"alignItems": "stretch",
					"columnGap": "xs"
				}
			}
		},
		"flexChild": {
			"renderCSS": true,
			"component": "flexChild",
			"nonInheritable": true,
			"type": "object",
			"varPrefix": "--kbs-cont-",
			"initial": {
				"desktop": {
					"flex": "initial"
				}
			}
		},
		"padding": {
			"type": "object",
			"renderCSS": true,
			"component": "padding",
			"nonInheritable": true,
			"varPrefix": "--kbs-cont-"
		},
		"margin": {
			"type": "object",
			"renderCSS": true,
			"component": "margin",
			"nonInheritable": true,
			"varPrefix": "--kbs-cont-",
			"selectorSuffix": "%selector%"
		},
		"background": {
			"renderCSS": true,
			"component": "background",
			"nonInheritable": true,
			"type": "object",
			"varPrefix": "--kbs-cont-",
			"classPrefix": "kbs-cont-bg-",
			"hasLayers": true
		},
		"boxShadow": {
			"renderCSS": true,
			"component": "boxShadow",
			"nonInheritable": true,
			"type": "object",
			"varPrefix": "--kbs-cont-",
			"classPrefix": "kbs-cont-shadow-",
			"hasLayers": true
		},
		"border": {
			"renderCSS": true,
			"component": "border",
			"nonInheritable": true,
			"type": "object",
			"varPrefix": "--kbs-cont-",
			"classPrefix": "kbs-cont-border-",
			"debug": true
		},
		"variant": {
			"renderCSS": false,
			"component": "containerVariant",
			"bundlePreset": true,
			"nonInheritable": true,
			"type": "string"
		},
		"color": {
			"type": "object"
		},
		"shadow": {
			"type": "object"
		},
		"visibility": {
			"type": "object"
		},
		"grow": {
			"type": "object"
		},
		"zIndex": {
			"type": "number"
		},
		"order": {
			"type": "object"
		},
		"basis": {
			"type": "object"
		},
		"width": {
			"type": "object"
		},
		"height": {
			"type": "object"
		},
		"templateLock": {
			"type": ["string", "boolean"],
			"enum": ["all", "insert", "contentOnly", false]
		},
		"link": {
			"type": "string"
		},
		"linkExtras": {
			"type": "object"
		},
		"minHeight": {
			"renderCSS": true,
			"component": "minHeight",
			"varPrefix": "--kbs-cont-",
			"nonInheritable": true,
			"initial": {},
			"type": "object"
		},
		"maxWidth": {
			"renderCSS": true,
			"component": "maxWidth",
			"varPrefix": "--kbs-cont-",
			"selectorSuffix": "%selector%",
			"nonInheritable": true,
			"initial": {},
			"type": "object"
		},
		"typography": {
			"renderCSS": true,
			"component": "typography",
			"varPrefix": "--kbs-cont-",
			"tag": "h1",
			"initial": {},
			"type": "object"
		},
		"globalStyleIds": {
			"type": "array"
		},
		"transform": {
			"renderCSS": true,
			"component": "transform",
			"nonInheritable": true,
			"selector": "--kbs-container-transform-",
			"classPrefix": "kbs-container-transform-",
			"initial": {},
			"type": "object"
		},
		"transformHover": {
			"renderCSS": true,
			"component": "transform",
			"nonInheritable": true,
			"selector": "--kbs-container-transform-",
			"classPrefix": "kbs-container-transform-",
			"initial": {},
			"type": "object"
		},
		"transition": {
			"renderCSS": true,
			"component": "transition",
			"nonInheritable": true,
			"selector": "--kbs-container-transition-",
			"classPrefix": "kbs-container-transition-",
			"initial": {},
			"type": "object"
		}
	},
	"supports": {
		"anchor": true,
		"ktanimate": true,
		"ktanimateadd": true,
		"ktanimatepreview": true,
		"ktanimateswipe": true,
		"ktdynamic": true,
		"kbcss": true,
		"kbMetadata": true,
		"align": ["wide", "full"]
	},
	"editorStyle": "kbs-section-editor",
	"style": "kbs-section"
}
