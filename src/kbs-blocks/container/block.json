{
	"apiVersion": 3,
	"title": "Container",
	"name": "kbs/container",
	"category": "kadence-blocks",
	"usesContext": ["postId", "queryId", "kbs/globalStyles", "kadence/dynamicSource", "kadence/repeaterRowData", "kadence/repeaterRow"],
	"textdomain": "kadence-blocks",
	"attributes": {
		"uniqueID": {
			"type": "string"
		},
		"anchor": {
			"type": "string"
		},
		"preset": {
			"type": "array"
		},
		"htmlTag": {
			"type": "string",
			"initial": "section"
		},
		"direction": {
			"renderCSS": true,
			"selector": "--kbs-cont-direction",
			"initial": { "desktop": "column" },
			"property": "flex-direction",
			"type": "object"
		},
		"justify": {
			"renderCSS": true,
			"selector": "--kbs-cont-justify",
			"initial": { "desktop": "flex-start" },
			"property": "justify-content",
			"type": "object"
		},
		"alignContent": {
			"renderCSS": true,
			"selector": "--kbs-cont-align-content",
			"initial": { "desktop": "initial" },
			"property": "align-content",
			"type": "object"
		},
		"alignItems": {
			"renderCSS": true,
			"selector": "--kbs-cont-align-items",
			"initial": { "desktop": "initial" },
			"property": "align-items",
			"type": "object"
		},
		"wrap": {
			"renderCSS": true,
			"selector": "--kbs-cont-wrap",
			"initial": { "desktop": "initial" },
			"property": "flex-wrap",
			"type": "object"
		},
		"columnGap": {
			"renderCSS": true,
			"selector": "--kbs-cont-column-gap",
			"initial": { "desktop": "xs" },
			"property": "column-gap",
			"type": "object"
		},
		"rowGap": {
			"renderCSS": true,
			"selector": "--kbs-cont-row-gap",
			"property": "row-gap",
			"type": "object"
		},
		"color": {
			"type": "object"
		},
		"background": {
			"type": "object"
		},
		"border": {
			"type": "object"
		},
		"padding": {
			"type": "object"
		},
		"margin": {
			"type": "object"
		},
		"shadow": {
			"type": "object"
		},
		"visibility": {
			"type": "object"
		},
		"grow": {
			"type": "object"
		},
		"zIndex": {
			"type": "number"
		},
		"order": {
			"type": "object"
		},
		"basis": {
			"type": "object"
		},
		"width": {
			"type": "object"
		},
		"height": {
			"type": "object"
		},
		"templateLock": {
			"type": ["string", "boolean"],
			"enum": ["all", "insert", "contentOnly", false]
		},
		"link": {
			"type": "string"
		},
		"linkExtras": {
			"type": "object"
		}
	},
	"supports": {
		"anchor": true,
		"ktanimate": true,
		"ktanimateadd": true,
		"ktanimatepreview": true,
		"ktanimateswipe": true,
		"ktdynamic": true,
		"kbcss": true,
		"kbMetadata": true,
		"align": [ "wide", "full" ]
	},
	"renderStyles": {
		"flex-direction": "direction",
		"justify-content": "justify",
		"align-items": "alignItems",
		"align-content": "alignContent",
		"gap": "gap",
		"wrap": "wrap",
		"flex-wrap": "wrap"
	},
	"editorStyle": "kbs-section-editor",
	"style": "kbs-section"
}
